RESEND_API_KEY=
CONTACT_TO_EMAIL=amnart.gl@gmail.com
# Must be a sender address from a domain verified in Resend.
CONTACT_FROM_EMAIL="AI Production Partner <contact@your-domain.com>"

# Privacy-friendly analytics (Plausible). Set to your site domain to enable
# pageview + outbound-link tracking. Leave empty to disable analytics entirely.
NEXT_PUBLIC_ANALYTICS_DOMAIN=

# External booking/scheduling URL (Cal.com, Calendly, etc.). When set, the
# assessment page shows a "Book a call" button. Leave empty for form-only.
NEXT_PUBLIC_BOOKING_URL=
